# ─── Datenbank (MariaDB) ──────────────────────────
DB_ROOT_PASSWORD=CHANGE_ME
DB_DATABASE=serviceheft
DB_USER=serviceheft
DB_PASSWORD=CHANGE_ME
DB_EXTERNAL_PORT=3306

# ─── App-Ports ────────────────────────────────────
APP_PORT=3001
UDP_PORT=41234
